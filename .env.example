PORT=3001
# Must match the database you're viewing in Compass (e.g. staging_db)
MONGODB_URI=mongodb://localhost:27017/staging_db
# Same Clerk app as the web app (Dashboard → API Keys → Secret key)
CLERK_SECRET_KEY=sk_test_...
# Fix 401: use JWT public key (PEM) for offline verification. See CLERK_SETUP.md.
# Option 1: path to a file containing the PEM (easiest — paste key with real newlines)
# CLERK_JWT_KEY_PATH=clerk-jwt.pem
# Option 2: PEM in one line (use \n for newlines)
# CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
CORS_ORIGIN=http://localhost:3000
# Optional: only for production; comma-separated frontend origins to validate azp
# CLERK_AUTHORIZED_PARTIES=https://yourdomain.com
