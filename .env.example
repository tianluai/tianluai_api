# Nest API — copy to `.env` (keep real secrets out of git).

NODE_ENV=development

PORT=3001
MONGODB_URI=mongodb://127.0.0.1:27017/tianluai

# Required — Bearer JWT from Next.js (must match `AUTH_JWT_SECRET` in `tianluai-web`). Generate: `openssl rand -base64 32`
AUTH_JWT_SECRET=

CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
# Public base URL of this API (no trailing slash). Used for Drive OAuth if `GOOGLE_REDIRECT_URI` is unset.
# Production: MUST be the API host (e.g. https://ai-api.tianlu.tech), NOT the Next.js frontend. If this is wrong,
# Google returns Error 400: redirect_uri_mismatch for Drive connection.
API_PUBLIC_URL=http://localhost:3001

# Sentry (optional)
SENTRY_DSN=

# --- Clerk (paused) ---
# CLERK_SECRET_KEY=

# Google OAuth (workspace Drive) — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match Google "Authorized redirect URIs" exactly. Default: {API_PUBLIC_URL}/drive/callback
# GOOGLE_REDIRECT_URI=http://localhost:3001/drive/callback

# OpenAI (chat / indexing)
OPENAI_API_KEY=

# Pinecone (vector store)
PINECONE_API_KEY=
PINECONE_INDEX=

# Redis (BullMQ)
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
