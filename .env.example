PORT=3001
# Must match the database you're viewing in Compass (e.g. staging_db)
MONGODB_URI=mongodb://localhost:27017/staging_db
# Clerk: JWT public key (PEM) for verifying tokens. Dashboard → JWT Templates → your template → Signing key (PEM). Use \n for newlines in .env.
CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
CORS_ORIGIN=http://localhost:3000
# Optional: only for production; comma-separated frontend origins to validate azp
# CLERK_AUTHORIZED_PARTIES=https://yourdomain.com

# Sentry (optional; get DSN from https://sentry.io)
# SENTRY_DSN=https://...@.../...
