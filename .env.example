# Nest API — copy to .env and fill values (see https://dashboard.clerk.com for Clerk keys)

PORT=3001
MONGODB_URI=mongodb://127.0.0.1:27017/tianluai
CLERK_SECRET_KEY=
CORS_ORIGIN=http://localhost:3000

# Sentry (optional — same DSN as your Sentry project; leave empty to disable)
SENTRY_DSN=

# Google OAuth (Drive) — use https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public URL of this API (no trailing slash). Used if GOOGLE_REDIRECT_URI is unset.
API_PUBLIC_URL=http://localhost:3001
# Must match Google "Authorized redirect URIs" exactly. Default: {API_PUBLIC_URL or http://localhost:PORT}/drive/callback
# GOOGLE_REDIRECT_URI=http://localhost:3001/drive/callback
FRONTEND_URL=http://localhost:3000
